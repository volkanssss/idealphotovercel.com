
{
  "rewrites": [
    { "source": "/ads.txt", "destination": "/ads.txt" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" },
        { "key": "Link", "value": "<https://idealphotovercel.com>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    },
    {
      "source": "/digibooth",
      "headers": [
        { "key": "Link", "value": "<https://idealphotovercel.com/digibooth>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/pica-pica-booth",
      "headers": [
        { "key": "Link", "value": "<https://idealphotovercel.com/pica-pica-booth>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/kpop-photo-booth",
      "headers": [
        { "key": "Link", "value": "<https://idealphotovercel.com/kpop-photo-booth>; rel=\"canonical\"" }
      ]
    },
    {
      "source": "/vintage-photobooth",
      "headers": [
        { "key": "Link", "value": "<https://idealphotovercel.com/vintage-photobooth>; rel=\"canonical\"" }
      ]
    }
  ]
}
